# Copy this file to .env next to Moasicly.exe, in the project folder, or create:
# %USERPROFILE%\.class_balancer\.env
#
# AI is optional. The app works without these tokens.
# AI is never used as the assignment engine.

CLASS_BALANCER_AI_ENABLED=false
CLASS_BALANCER_AI_PROVIDER=OpenAI

# Put only the provider you actually use:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional model overrides:
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_MODEL=gemini-1.5-flash

# Optional custom SQLite path:
# CLASS_BALANCER_DB=D:\classmaker\class_balancer.sqlite3
